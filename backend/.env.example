# Copy to .env and adjust as needed. All variables are optional.
DOCCHAT_ENVIRONMENT=development
DOCCHAT_LOG_LEVEL=INFO

# Passage construction
DOCCHAT_PASSAGE_WINDOW=4
DOCCHAT_PASSAGE_STRIDE=2

# Retrieval / ranking (hybrid: BM25 + TF-IDF + LSA)
DOCCHAT_TOP_K_PASSAGES=5
DOCCHAT_TOP_K_ANSWERS=3
DOCCHAT_CONTEXT_SENTENCES=1
DOCCHAT_BM25_WEIGHT=0.5
DOCCHAT_TFIDF_WEIGHT=0.3
DOCCHAT_LSA_WEIGHT=0.2
DOCCHAT_MIN_ANSWER_SCORE=0.0

# Dense retrieval (LSA / TruncatedSVD — classical, no LLM)
DOCCHAT_LSA_ENABLED=true
DOCCHAT_LSA_COMPONENTS=128

# Ingestion
DOCCHAT_MAX_FILE_BYTES=52428800

# API
DOCCHAT_API_TITLE=Doc Chat API
DOCCHAT_API_VERSION=0.2.0
# JSON array of allowed CORS origins (use ["*"] for open dev access)
DOCCHAT_CORS_ORIGINS=["*"]

# Auth (optional): JSON array of valid API keys. Empty = auth disabled.
DOCCHAT_API_KEYS=[]

# Storage / background processing
DOCCHAT_STORAGE_DIR=./data
DOCCHAT_INGEST_WORKERS=2
# Max in-memory QA engines kept (LRU); evicted ones are rebuilt on demand
DOCCHAT_ENGINE_CACHE_SIZE=32
# Store backend: "json" (default, single-node) or "sql" (SQLite/Postgres/Neon)
DOCCHAT_STORE_BACKEND=json
# SQLAlchemy URL for the sql backend (blank = SQLite under storage_dir).
# For Neon Postgres, paste the connection string from the Neon dashboard, e.g.:
#   DOCCHAT_STORE_BACKEND=sql
#   DOCCHAT_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
# (postgres:// and postgresql:// URLs are auto-upgraded to the psycopg3 driver.)
DOCCHAT_DATABASE_URL=

# OCR (requires the `tesseract` binary on PATH)
DOCCHAT_OCR_ENABLED=true
DOCCHAT_OCR_LANGUAGE=eng

# LibreOffice fallback for legacy .doc/.rtf/.odt (requires `soffice` on PATH)
DOCCHAT_LIBREOFFICE_ENABLED=true
