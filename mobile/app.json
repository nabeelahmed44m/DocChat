{
  "expo": {
    "name": "Gist",
    "slug": "gist-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gist",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0B0D",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nabeel.gistapp",
      "infoPlist": {
        "NSCameraUsageDescription": "Gist uses the camera so you can scan a paper document and ask questions about it.",
        "NSPhotoLibraryUsageDescription": "Gist needs access to your photos so you can upload an image of a document."
      }
    },
    "android": {
      "package": "com.gistapp.gist",
      "adaptiveIcon": {
        "backgroundColor": "#5645D4",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#5645D4",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Gist needs access to your photos so you can upload an image of a document.",
          "cameraPermission": "Gist uses the camera so you can scan a paper document and ask questions about it."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
