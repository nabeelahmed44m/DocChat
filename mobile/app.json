{
  "expo": {
    "name": "Doc Chat",
    "slug": "doc-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "docchat",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0B0D",
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Doc Chat uses the camera so you can scan a paper document and ask questions about it.",
        "NSPhotoLibraryUsageDescription": "Doc Chat needs access to your photos so you can upload an image of a document."
      },
      "bundleIdentifier": "com.anonymous.doc-chat"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0B0D",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0B0D",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Doc Chat needs access to your photos so you can upload an image of a document.",
          "cameraPermission": "Doc Chat uses the camera so you can scan a paper document and ask questions about it."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
